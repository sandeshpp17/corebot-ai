APP_NAME=corebot-ai
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
API_KEY=corebot-dev-key
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key
CORS_ALLOW_CREDENTIALS=false

DATABASE_URL=postgresql+psycopg2://corebot:corebot@localhost:5432/corebot

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_DIM=768
OLLAMA_TIMEOUT_SEC=120
OLLAMA_EMBED_CONCURRENCY=8
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SEC=300

CHUNK_SIZE=600
CHUNK_OVERLAP=60
RETRIEVE_TOP_K=3
RETRIEVE_MIN_SCORE=0.6
MAX_UPLOAD_BYTES=5242880
MAX_HISTORY_MESSAGES=20
MAX_MESSAGE_CHARS=4000
ALLOWED_MIME_TYPES=text/plain,text/markdown,application/json
MAX_INGEST_JOBS=200
INGEST_JOB_TTL_SEC=3600
WEBAPP_TOOLS_ENABLED=false
WEBAPP_DIAGNOSTICS_BASE_URL=
WEBAPP_DIAGNOSTICS_TOKEN=
